generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String         @id @default(uuid())
  email                 String         @unique
  password              String
  role                  Role
  createdAt             DateTime       @default(now())
  isActive              Boolean        @default(true)
  updatedAt             DateTime       @updatedAt
  isEmailVerified       Boolean        @default(false)
  otp                   String?
  otpExpiry             DateTime?
  otpAttempts           Int            @default(0)
  otpLastAttempt        DateTime?
  refreshTokenExpiresAt DateTime?
  refreshTokenHash      String?
  passwordResetExpiry   DateTime?
  passwordResetOtp      String?
  adminPermissions      String[]       @default([])
  lastLoginAt           DateTime?
  notifications         Notification[]
  supplier              Supplier?
  sessions              UserSession[]
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  deviceType String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  isActive   Boolean  @default(true)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Supplier {
  id              String         @id @default(uuid())
  userId          String         @unique
  companyName     String
  status          SupplierStatus @default(DRAFT)
  address         String
  city            String
  country         String
  gstNumber       String
  internalNotes   String?
  leadTimeDays    Int
  monthlyCapacity Int
  moq             Int
  responseTimeHr  Int
  trustScore      Int?
  workforceSize   Int
  yearEstablished Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  panNumber       String
  rejectionReason String?
  documents       Document[]
  orders          Order[]
  products        Product[]
  user            User           @relation(fields: [userId], references: [id])
}

model Document {
  id              String         @id @default(uuid())
  supplierId      String
  type            String
  fileUrl         String
  fileKey         String?
  uploadedAt      DateTime       @default(now())
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedBy      String?
  status          DocumentStatus @default(PENDING)
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
}

model Product {
  id              String           @id @default(uuid())
  supplierId      String
  name            String
  category        String
  isLive          Boolean          @default(false)
  createdAt       DateTime         @default(now())
  leadTime        Int
  moq             Int
  specs           Json
  status          ProductStatus    @default(DRAFT)
  description     String?
  price           Float?
  unit            String?
  updatedAt       DateTime         @updatedAt
  rejectionReason String?
  orders          Order[]
  supplier        Supplier         @relation(fields: [supplierId], references: [id])
  variants        ProductVariant[]
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  sku       String?
  name      String
  price     Float?
  stock     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RevokedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  reason    String   @default("logout")
  revokedAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([token])
}

model SystemConfig {
  id                     String   @id @default("singleton")
  isMaintenanceMode      Boolean  @default(false)
  minTrustScore          Int      @default(30)
  defaultTrustScore      Int      @default(50)
  maxFailedLogins        Int      @default(5)
  defaultSupplierStatus  String   @default("DRAFT")
  onboardingEnabled      Boolean  @default(true)
  productPublishing      Boolean  @default(true)
  businessCommission     Float    @default(10.0)
  updatedAt              DateTime @updatedAt
  allowNewRegistrations  Boolean  @default(true)
  maxProductsPerSupplier Int      @default(50)
  platformName           String   @default("Delraw")
  supplierAutoApprove    Boolean  @default(false)
  supportEmail           String   @default("support@delraw.com")
  updatedBy              String?
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  supplierId     String
  productId      String
  quantity       Int
  totalAmount    Float
  commissionPaid Float
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  product        Product     @relation(fields: [productId], references: [id])
  supplier       Supplier    @relation(fields: [supplierId], references: [id])
}

enum Role {
  SUPPLIER
  ADMIN
  SUPER_ADMIN
}

enum SupplierStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REJECTED
  SUSPENDED
  UNDER_REVIEW
  CONDITIONAL
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  LIVE
  REJECTED
  DELISTED
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
