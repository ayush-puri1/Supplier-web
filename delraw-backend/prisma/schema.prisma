generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1️⃣ SYSTEM OVERVIEW (Enums)

enum Role {
  SUPPLIER
  ADMIN
  SUPER_ADMIN
}

enum SupplierStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  CONDITIONAL
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  LIVE
  REJECTED
  DELISTED
}

// 2️⃣ DATABASE DESIGN (Models)

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  isActive        Boolean   @default(true)
  otp             String?
  otpExpiry       DateTime?
  isEmailVerified Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier      Supplier?
  notifications Notification[]
}

model Supplier {
  id              String         @id @default(uuid())
  userId          String         @unique
  companyName     String
  gstNumber       String
  address         String
  city            String
  country         String
  panNumber       String
  yearEstablished Int
  workforceSize   Int
  monthlyCapacity Int
  moq             Int
  leadTimeDays    Int
  responseTimeHr  Int
  status          SupplierStatus @default(DRAFT)
  trustScore      Int?
  internalNotes   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  documents Document[]
  products  Product[]
  orders    Order[]
}

model Document {
  id         String   @id @default(uuid())
  supplierId String
  type       String
  fileUrl    String
  verified   Boolean  @default(false)
  uploadedAt DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model Product {
  id          String        @id @default(uuid())
  supplierId  String
  name        String
  description String?
  category    String
  specs       Json
  moq         Int
  leadTime    Int
  price       Float?
  unit        String?
  images      String[]
  status      ProductStatus @default(DRAFT)
  isLive      Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  supplier Supplier         @relation(fields: [supplierId], references: [id])
  orders   Order[]
  variants ProductVariant[]
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  sku       String?
  name      String
  price     Float?
  stock     Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actorEmail String?
  action     String
  entityType String
  entityId   String
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model RevokedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  reason    String   @default("logout")
  revokedAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([token])
}

model SystemConfig {
  id                    String   @id @default("singleton")
  isMaintenanceMode     Boolean  @default(false)
  minTrustScore         Int      @default(30)
  defaultTrustScore     Int      @default(50)
  maxFailedLogins       Int      @default(5)
  defaultSupplierStatus String   @default("DRAFT")
  onboardingEnabled     Boolean  @default(true)
  productPublishing     Boolean  @default(true)
  businessCommission    Float    @default(10.0)
  updatedAt             DateTime @updatedAt
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  supplierId     String
  productId      String
  quantity       Int
  totalAmount    Float
  commissionPaid Float
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  supplier       Supplier    @relation(fields: [supplierId], references: [id])
  product        Product     @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}